{
  "name": "wirts-world-auth",
  "main": "worker.js",
  "compatibility_date": "2026-05-04",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "auth.wirts.world",
      "custom_domain": true,
      "zone_name": "wirts.world"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONTENT",
      "id": "0257be7978424b7eb842c9852c0752d5"
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
